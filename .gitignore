# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User settings
xcuserdata/

## Compatibility with Xcode 8 and earlier (Objective-C or Swift)
*.xcscmblueprint
*.xccheckout

## Compatibility with Xcode 3 and earlier (Objective-C)
*.mode1v3
*.perspectivev3
*.pbxuser
!default.pbxuser
*.mode2v3
*.suo
*.user
*.userdoc
*.xcuserstate
*.xcscmblueprint

## Obj-C/Swift specific
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager
#
# Add this line if you want to avoid checking in source code from SPM dependencies.
# Packages/
# Package.pins
# Package.resolved
# *.xcodeproj
#
# Xcode automatically generates this directory with a hierarchical structure
# of converted external modules. Check it in if you want to.
# .swiftpm/

# CocoaPods
#
# We recommend against adding the Pods directory to your source control.
# Instead, consider adding the Podfile and/or Cartfile to source control.
Pods/

# Carthage
#
# Add this line if you want to avoid checking in source code from Carthage dependencies.
# Carthage/Checkouts

Carthage/Build/

# Accio dependency management
Dependencies/
.accio/

# fastlane
#
# It is recommended to not store the screenshots in the git repo.
# Instead, use fastlane to re-generate the screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Code Injection
#
# After new build tool is integrated, .generated directory serves as a place for generated source files.
iOSInjectionProject/
*.generated.swift

# Build outputs
DerivedData/
Build/
*.xcarchive

# Temporary files
*.tmp
*.temp
.DS_Store

# Documentation
POLISH.md
iOS27_COMPLIANCE.md
